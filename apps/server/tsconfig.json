{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node"],
    "baseUrl": ".",
    // "paths": {
    //   "@repo/types": ["../../packages/types/dist/index.d.ts"],
    //   "@repo/crypto": ["../../packages/crypto/dist/index.d.ts"]
    // },

    "rootDir": "./src",
    "outDir": "./dist",
    "moduleResolution": "NodeNext",  // ← was "bundler", must match @repo/db

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
