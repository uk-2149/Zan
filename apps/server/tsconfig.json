{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node"],

    "rootDir": "./src",
    "outDir": "./dist",
    "moduleResolution": "NodeNext",  // ← was "bundler", must match @repo/db

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
    // ← remove "paths" entirely; use package.json workspaces instead
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}